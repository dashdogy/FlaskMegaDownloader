[Unit]
Description=Flask Mega Downloader
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/flask-mega-downloader
Environment=MEGA_DOWNLOADER_CONFIG=/etc/flask-mega-downloader/config.py
ExecStart=/opt/flask-mega-downloader/.venv/bin/waitress-serve --listen=0.0.0.0:8080 --call app:create_app
Restart=on-failure
RestartSec=5
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
